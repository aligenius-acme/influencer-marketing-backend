// Prisma Schema for Influencer Marketing Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== User Management ====================

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String?      @map("password_hash")
  role          UserRole     @default(BRAND)
  emailVerified Boolean      @default(false) @map("email_verified")
  avatarUrl     String?      @map("avatar_url")
  googleId      String?      @unique @map("google_id")
  authProvider  AuthProvider @default(LOCAL) @map("auth_provider")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Stripe fields
  stripeCustomerId String? @unique @map("stripe_customer_id")

  // Relations
  brandProfile            BrandProfile?
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  campaigns               Campaign[]
  activities              CampaignActivity[]
  emailTemplates          EmailTemplate[]
  subscription            Subscription?
  payments                Payment[]
  shopifyStore            ShopifyStore?

  @@map("users")
}

enum UserRole {
  BRAND
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model BrandProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyName String   @map("company_name")
  industry    String?
  website     String?
  logoUrl     String?  @map("logo_url")
  description String?
  socialLinks Json     @default("{}") @map("social_links")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ==================== Campaign Management ====================

model Campaign {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  name        String
  description String?
  brief       String?
  platform    String?
  campaignType String?       @map("campaign_type")
  budget      Decimal?       @db.Decimal(12, 2)
  currency    String         @default("USD")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  goals       Json           @default("{}")
  status      CampaignStatus @default(DRAFT)
  hashtags    String[]       @default([])
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  influencers     CampaignInfluencer[]
  activities      CampaignActivity[]
  seedingCampaign SeedingCampaign?

  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model CampaignInfluencer {
  id                  String                    @id @default(uuid())
  campaignId          String                    @map("campaign_id")
  savedInfluencerId   String                    @map("saved_influencer_id")
  status              CampaignInfluencerStatus  @default(INVITED)
  agreedRate          Decimal?                  @map("agreed_rate") @db.Decimal(10, 2)
  currency            String                    @default("USD")
  deliverables        Json                      @default("[]")
  contentUrls         Json                      @default("[]") @map("content_urls")
  notes               String?
  invitedAt           DateTime?                 @map("invited_at")
  acceptedAt          DateTime?                 @map("accepted_at")
  completedAt         DateTime?                 @map("completed_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  // Relations
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  discountCodes    DiscountCode[]
  seedingShipments SeedingShipment[]

  @@map("campaign_influencers")
}

enum CampaignInfluencerStatus {
  INVITED
  NEGOTIATING
  ACCEPTED
  DECLINED
  CONTENT_PENDING
  CONTENT_SUBMITTED
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  COMPLETED
}

model CampaignActivity {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  userId       String?  @map("user_id")
  activityType String   @map("activity_type")
  description  String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@map("campaign_activities")
}

// ==================== Email Templates (Phase 2) ====================

model EmailTemplate {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  subject      String
  body         String
  templateType String   @map("template_type")
  variables    Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

// ==================== Payments & Subscriptions ====================

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripePriceId        String             @map("stripe_price_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

model Payment {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  stripePaymentId String        @unique @map("stripe_payment_id")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  description     String?
  invoiceUrl      String?       @map("invoice_url")
  receiptUrl      String?       @map("receipt_url")
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ==================== Shopify E-commerce Integration ====================

model ShopifyStore {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  shopDomain  String    @unique @map("shop_domain") // mystore.myshopify.com
  accessToken String    @map("access_token")
  scope       String    // Granted scopes

  storeName   String?   @map("store_name")
  storeEmail  String?   @map("store_email")
  currency    String    @default("USD")

  lastSyncAt  DateTime? @map("last_sync_at")
  webhookId   String?   @map("webhook_id")

  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      ShopifyProduct[]
  discountCodes DiscountCode[]

  @@map("shopify_stores")
}

model ShopifyProduct {
  id               String   @id @default(uuid())
  storeId          String   @map("store_id")
  shopifyProductId String   @map("shopify_product_id")
  title            String
  description      String?
  handle           String   // URL handle
  imageUrl         String?  @map("image_url")
  price            Decimal  @db.Decimal(12, 2)
  compareAtPrice   Decimal? @db.Decimal(12, 2) @map("compare_at_price")
  currency         String   @default("USD")

  variants    Json     @default("[]") // Array of variant data
  tags        String[] @default([])
  productType String?  @map("product_type")
  vendor      String?

  isAvailable Boolean  @default(true) @map("is_available")
  syncedAt    DateTime @default(now()) @map("synced_at")

  // Relations
  store ShopifyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopifyProductId])
  @@map("shopify_products")
}

model DiscountCode {
  id                   String   @id @default(uuid())
  storeId              String   @map("store_id")
  campaignInfluencerId String?  @map("campaign_influencer_id")

  code                 String   // INFLUENCER20
  shopifyPriceRuleId   String?  @map("shopify_price_rule_id")
  shopifyDiscountId    String?  @map("shopify_discount_id")

  discountType  String  @map("discount_type") // PERCENTAGE, FIXED_AMOUNT
  discountValue Decimal @db.Decimal(10, 2) @map("discount_value")

  usageCount Int  @default(0) @map("usage_count")
  maxUses    Int? @map("max_uses")

  startsAt  DateTime? @map("starts_at")
  expiresAt DateTime? @map("expires_at")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  store              ShopifyStore        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaignInfluencer CampaignInfluencer? @relation(fields: [campaignInfluencerId], references: [id])
  attributedSales    AttributedSale[]

  @@unique([storeId, code])
  @@map("discount_codes")
}

model AttributedSale {
  id             String   @id @default(uuid())
  discountCodeId String   @map("discount_code_id")

  shopifyOrderId String @map("shopify_order_id")
  orderNumber    String @map("order_number")

  subtotal       Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @db.Decimal(12, 2) @map("discount_amount")
  totalPrice     Decimal  @db.Decimal(12, 2) @map("total_price")
  currency       String   @default("USD")

  customerEmail  String?  @map("customer_email")

  commission     Decimal? @db.Decimal(12, 2) // Calculated influencer commission
  commissionRate Decimal? @db.Decimal(5, 2) @map("commission_rate") // Percentage

  orderDate DateTime @map("order_date")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@unique([discountCodeId, shopifyOrderId])
  @@map("attributed_sales")
}

model SeedingCampaign {
  id         String @id @default(uuid())
  campaignId String @unique @map("campaign_id")

  products             Json    @default("[]") // Array of {productId, variantId, quantity}
  shippingInstructions String? @map("shipping_instructions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  campaign  Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shipments SeedingShipment[]

  @@map("seeding_campaigns")
}

model SeedingShipment {
  id                   String @id @default(uuid())
  seedingCampaignId    String @map("seeding_campaign_id")
  campaignInfluencerId String @map("campaign_influencer_id")

  status         ShipmentStatus @default(PENDING)
  trackingNumber String?        @map("tracking_number")
  carrier        String?        // USPS, FedEx, UPS, etc.

  shippingAddress Json?    @map("shipping_address")
  products        Json     @default("[]") // Products in this shipment

  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  seedingCampaign    SeedingCampaign    @relation(fields: [seedingCampaignId], references: [id], onDelete: Cascade)
  campaignInfluencer CampaignInfluencer @relation(fields: [campaignInfluencerId], references: [id])

  @@map("seeding_shipments")
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  RETURNED
}
