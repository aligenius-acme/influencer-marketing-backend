// Prisma Schema for Influencer Marketing Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== User Management ====================

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String?      @map("password_hash")
  role          UserRole     @default(BRAND)
  emailVerified Boolean      @default(false) @map("email_verified")
  avatarUrl     String?      @map("avatar_url")
  googleId      String?      @unique @map("google_id")
  authProvider  AuthProvider @default(LOCAL) @map("auth_provider")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Stripe fields
  stripeCustomerId String? @unique @map("stripe_customer_id")

  // Relations
  brandProfile            BrandProfile?
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  campaigns               Campaign[]
  activities              CampaignActivity[]
  emailTemplates          EmailTemplate[]
  subscription            Subscription?
  payments                Payment[]
  shopifyStore            ShopifyStore?

  // Phase 3 Relations
  socialMediaConnections SocialMediaConnection[]
  contractTemplates      ContractTemplate[]
  contracts              Contract[]
  syncJobs               SyncJob[]

  @@map("users")
}

enum UserRole {
  BRAND
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model BrandProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyName String   @map("company_name")
  industry    String?
  website     String?
  logoUrl     String?  @map("logo_url")
  description String?
  socialLinks Json     @default("{}") @map("social_links")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ==================== Campaign Management ====================

model Campaign {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  name        String
  description String?
  brief       String?
  platform    String?
  campaignType String?       @map("campaign_type")
  budget      Decimal?       @db.Decimal(12, 2)
  currency    String         @default("USD")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  goals       Json           @default("{}")
  status      CampaignStatus @default(DRAFT)
  hashtags    String[]       @default([])
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  influencers     CampaignInfluencer[]
  activities      CampaignActivity[]
  seedingCampaign SeedingCampaign?

  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model CampaignInfluencer {
  id                  String                    @id @default(uuid())
  campaignId          String                    @map("campaign_id")
  savedInfluencerId   String                    @map("saved_influencer_id")
  status              CampaignInfluencerStatus  @default(INVITED)
  agreedRate          Decimal?                  @map("agreed_rate") @db.Decimal(10, 2)
  currency            String                    @default("USD")
  deliverables        Json                      @default("[]")
  contentUrls         Json                      @default("[]") @map("content_urls")
  notes               String?
  invitedAt           DateTime?                 @map("invited_at")
  acceptedAt          DateTime?                 @map("accepted_at")
  completedAt         DateTime?                 @map("completed_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  // Relations
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  discountCodes    DiscountCode[]
  seedingShipments SeedingShipment[]

  @@map("campaign_influencers")
}

enum CampaignInfluencerStatus {
  INVITED
  NEGOTIATING
  ACCEPTED
  DECLINED
  CONTENT_PENDING
  CONTENT_SUBMITTED
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  COMPLETED
}

model CampaignActivity {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  userId       String?  @map("user_id")
  activityType String   @map("activity_type")
  description  String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@map("campaign_activities")
}

// ==================== Email Templates (Phase 2) ====================

model EmailTemplate {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  subject      String
  body         String
  templateType String   @map("template_type")
  variables    Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

// ==================== Payments & Subscriptions ====================

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripePriceId        String             @map("stripe_price_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

model Payment {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  stripePaymentId String        @unique @map("stripe_payment_id")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  description     String?
  invoiceUrl      String?       @map("invoice_url")
  receiptUrl      String?       @map("receipt_url")
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ==================== Shopify E-commerce Integration ====================

model ShopifyStore {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  shopDomain  String    @unique @map("shop_domain") // mystore.myshopify.com
  accessToken String    @map("access_token")
  scope       String    // Granted scopes

  storeName   String?   @map("store_name")
  storeEmail  String?   @map("store_email")
  currency    String    @default("USD")

  lastSyncAt  DateTime? @map("last_sync_at")
  webhookId   String?   @map("webhook_id")

  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      ShopifyProduct[]
  discountCodes DiscountCode[]

  @@map("shopify_stores")
}

model ShopifyProduct {
  id               String   @id @default(uuid())
  storeId          String   @map("store_id")
  shopifyProductId String   @map("shopify_product_id")
  title            String
  description      String?
  handle           String   // URL handle
  imageUrl         String?  @map("image_url")
  price            Decimal  @db.Decimal(12, 2)
  compareAtPrice   Decimal? @db.Decimal(12, 2) @map("compare_at_price")
  currency         String   @default("USD")

  variants    Json     @default("[]") // Array of variant data
  tags        String[] @default([])
  productType String?  @map("product_type")
  vendor      String?

  isAvailable Boolean  @default(true) @map("is_available")
  syncedAt    DateTime @default(now()) @map("synced_at")

  // Relations
  store ShopifyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopifyProductId])
  @@map("shopify_products")
}

model DiscountCode {
  id                   String   @id @default(uuid())
  storeId              String   @map("store_id")
  campaignInfluencerId String?  @map("campaign_influencer_id")

  code                 String   // INFLUENCER20
  shopifyPriceRuleId   String?  @map("shopify_price_rule_id")
  shopifyDiscountId    String?  @map("shopify_discount_id")

  discountType  String  @map("discount_type") // PERCENTAGE, FIXED_AMOUNT
  discountValue Decimal @db.Decimal(10, 2) @map("discount_value")

  usageCount Int  @default(0) @map("usage_count")
  maxUses    Int? @map("max_uses")

  startsAt  DateTime? @map("starts_at")
  expiresAt DateTime? @map("expires_at")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  store              ShopifyStore        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaignInfluencer CampaignInfluencer? @relation(fields: [campaignInfluencerId], references: [id])
  attributedSales    AttributedSale[]

  @@unique([storeId, code])
  @@map("discount_codes")
}

model AttributedSale {
  id             String   @id @default(uuid())
  discountCodeId String   @map("discount_code_id")

  shopifyOrderId String @map("shopify_order_id")
  orderNumber    String @map("order_number")

  subtotal       Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @db.Decimal(12, 2) @map("discount_amount")
  totalPrice     Decimal  @db.Decimal(12, 2) @map("total_price")
  currency       String   @default("USD")

  customerEmail  String?  @map("customer_email")

  commission     Decimal? @db.Decimal(12, 2) // Calculated influencer commission
  commissionRate Decimal? @db.Decimal(5, 2) @map("commission_rate") // Percentage

  orderDate DateTime @map("order_date")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@unique([discountCodeId, shopifyOrderId])
  @@map("attributed_sales")
}

model SeedingCampaign {
  id         String @id @default(uuid())
  campaignId String @unique @map("campaign_id")

  products             Json    @default("[]") // Array of {productId, variantId, quantity}
  shippingInstructions String? @map("shipping_instructions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  campaign  Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shipments SeedingShipment[]

  @@map("seeding_campaigns")
}

model SeedingShipment {
  id                   String @id @default(uuid())
  seedingCampaignId    String @map("seeding_campaign_id")
  campaignInfluencerId String @map("campaign_influencer_id")

  status         ShipmentStatus @default(PENDING)
  trackingNumber String?        @map("tracking_number")
  carrier        String?        // USPS, FedEx, UPS, etc.

  shippingAddress Json?    @map("shipping_address")
  products        Json     @default("[]") // Products in this shipment

  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  seedingCampaign    SeedingCampaign    @relation(fields: [seedingCampaignId], references: [id], onDelete: Cascade)
  campaignInfluencer CampaignInfluencer @relation(fields: [campaignInfluencerId], references: [id])

  @@map("seeding_shipments")
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  RETURNED
}

// ==================== Phase 3: Social Media Connections ====================

model SocialMediaConnection {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  platform       SocialPlatform
  platformUserId String         @map("platform_user_id")
  accessToken    String         @map("access_token")
  refreshToken   String?        @map("refresh_token")
  tokenExpiresAt DateTime?      @map("token_expires_at")
  scope          String?
  username       String?
  displayName    String?        @map("display_name")
  profileImage   String?        @map("profile_image")
  isActive       Boolean        @default(true) @map("is_active")
  lastSyncAt     DateTime?      @map("last_sync_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, platformUserId])
  @@map("social_media_connections")
}

enum SocialPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  TWITTER
}

// ==================== Phase 3: Contract Management ====================

model ContractTemplate {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  content     String   @db.Text
  mergeTags   Json     @default("[]") @map("merge_tags")
  category    String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@map("contract_templates")
}

model Contract {
  id                   String         @id @default(uuid())
  userId               String         @map("user_id")
  templateId           String?        @map("template_id")
  campaignId           String?        @map("campaign_id")
  campaignInfluencerId String?        @map("campaign_influencer_id")

  title   String
  content String         @db.Text
  status  ContractStatus @default(DRAFT)
  version Int            @default(1)

  // E-signature fields
  signatureProvider  String? @map("signature_provider") // docusign, hellosign
  externalDocumentId String? @map("external_document_id")
  signatureRequestId String? @map("signature_request_id")

  // Usage rights
  usageRights  Json     @default("{}") @map("usage_rights")
  exclusivity  String?
  territories  String[] @default([])
  contentTypes String[] @default([]) @map("content_types")

  // Dates
  effectiveDate  DateTime? @map("effective_date")
  expirationDate DateTime? @map("expiration_date")
  renewalDate    DateTime? @map("renewal_date")
  signedAt       DateTime? @map("signed_at")

  // Payment terms
  paymentAmount   Decimal? @db.Decimal(12, 2) @map("payment_amount")
  paymentCurrency String   @default("USD") @map("payment_currency")
  paymentSchedule Json?    @map("payment_schedule")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template ContractTemplate? @relation(fields: [templateId], references: [id])
  versions ContractVersion[]
  signers  ContractSigner[]

  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  PARTIALLY_SIGNED
  SIGNED
  ACTIVE
  EXPIRED
  CANCELLED
  RENEWED
}

model ContractVersion {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  version    Int
  content    String   @db.Text
  changes    String?
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, version])
  @@map("contract_versions")
}

model ContractSigner {
  id            String    @id @default(uuid())
  contractId    String    @map("contract_id")
  name          String
  email         String
  role          String // brand, influencer, agency
  signedAt      DateTime? @map("signed_at")
  signatureData Json?     @map("signature_data")
  ipAddress     String?   @map("ip_address")
  order         Int       @default(0)

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_signers")
}

// ==================== Phase 3: AI Features ====================

model InfluencerMatchScore {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  savedInfluencerId String  @map("saved_influencer_id")
  campaignId        String? @map("campaign_id")

  overallScore      Float @map("overall_score")
  audienceScore     Float @map("audience_score")
  engagementScore   Float @map("engagement_score")
  nicheScore        Float @map("niche_score")
  authenticityScore Float @map("authenticity_score")
  budgetFitScore    Float @map("budget_fit_score")

  explanation  Json?
  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@unique([userId, savedInfluencerId, campaignId])
  @@map("influencer_match_scores")
}

// ==================== Phase 3: Background Jobs ====================

model SyncJob {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  jobType     String    @map("job_type")
  status      JobStatus @default(PENDING)
  metadata    Json      @default("{}")
  result      Json?
  error       String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sync_jobs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==================== Phase 4: Workspace & Team Management ====================

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  ownerId     String   @map("owner_id")
  logoUrl     String?  @map("logo_url")
  description String?

  // Settings
  settings    Json     @default("{}") // Default timezone, currency, etc.

  // Plan & limits
  plan        WorkspacePlan @default(PROFESSIONAL)

  // Status
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  auditLogs   AuditLog[]
  apiKeys     ApiKey[]
  webhooks    Webhook[]
  branding    TenantBranding?

  @@map("workspaces")
}

enum WorkspacePlan {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

model WorkspaceMember {
  id          String         @id @default(uuid())
  workspaceId String         @map("workspace_id")
  userId      String         @map("user_id")
  role        WorkspaceRole  @default(MEMBER)
  permissions Json           @default("{}") // Custom permission overrides
  invitedBy   String?        @map("invited_by")
  joinedAt    DateTime       @default(now()) @map("joined_at")

  // Relations
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model WorkspaceInvitation {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  email       String
  role        WorkspaceRole    @default(MEMBER)
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  invitedBy   String           @map("invited_by")
  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  // Relations
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@map("workspace_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ==================== Phase 4: Audit Logging ====================

model AuditLog {
  id           String    @id @default(uuid())
  workspaceId  String?   @map("workspace_id")
  userId       String?   @map("user_id")

  action       String    // create, update, delete, view, export, etc.
  resourceType String    @map("resource_type") // campaign, influencer, contract, etc.
  resourceId   String?   @map("resource_id")
  resourceName String?   @map("resource_name") // Human-readable name

  oldValue     Json?     @map("old_value")
  newValue     Json?     @map("new_value")

  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")

  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ==================== Phase 4: API Access ====================

model ApiKey {
  id          String      @id @default(uuid())
  workspaceId String?     @map("workspace_id")
  userId      String      @map("user_id")

  name        String
  keyHash     String      @unique @map("key_hash") // Hashed API key
  keyPrefix   String      @map("key_prefix") // First 8 chars for display (e.g., "im_sk_abc...")

  permissions Json        @default("[]") // Array of allowed scopes

  // Rate limiting
  rateLimit   Int         @default(1000) @map("rate_limit") // Requests per minute

  // Usage tracking
  lastUsedAt  DateTime?   @map("last_used_at")
  usageCount  Int         @default(0) @map("usage_count")

  // Expiration
  expiresAt   DateTime?   @map("expires_at")
  isActive    Boolean     @default(true) @map("is_active")

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@map("api_keys")
}

model Webhook {
  id          String        @id @default(uuid())
  workspaceId String?       @map("workspace_id")
  userId      String        @map("user_id")

  name        String
  url         String
  secret      String        // For HMAC signature verification

  events      String[]      @default([]) // Array of event types to subscribe to

  // Status
  isActive    Boolean       @default(true) @map("is_active")

  // Delivery stats
  lastDeliveredAt DateTime? @map("last_delivered_at")
  lastStatus      Int?      @map("last_status") // HTTP status code
  failureCount    Int       @default(0) @map("failure_count")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  webhookId   String   @map("webhook_id")

  event       String
  payload     Json

  // Response
  statusCode  Int?     @map("status_code")
  response    String?  @db.Text

  // Timing
  duration    Int?     // Response time in ms
  deliveredAt DateTime @default(now()) @map("delivered_at")

  // Retry info
  attempt     Int      @default(1)

  // Relations
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, deliveredAt])
  @@map("webhook_deliveries")
}

// ==================== Phase 4: White-Label / Tenant Branding ====================

model TenantBranding {
  id          String   @id @default(uuid())
  workspaceId String   @unique @map("workspace_id")

  // Custom domain
  customDomain      String?  @unique @map("custom_domain")
  domainVerified    Boolean  @default(false) @map("domain_verified")
  domainVerifyToken String?  @map("domain_verify_token")

  // Branding
  primaryColor      String?  @map("primary_color")
  secondaryColor    String?  @map("secondary_color")
  accentColor       String?  @map("accent_color")
  logoUrl           String?  @map("logo_url")
  logomarkUrl       String?  @map("logomark_url") // Small icon version
  faviconUrl        String?  @map("favicon_url")

  // Email branding
  emailFromName     String?  @map("email_from_name")
  emailFromAddress  String?  @map("email_from_address")
  emailLogoUrl      String?  @map("email_logo_url")
  emailFooterText   String?  @map("email_footer_text")

  // Login page
  loginBackgroundUrl String? @map("login_background_url")
  loginWelcomeText   String? @map("login_welcome_text")

  // Feature flags
  hidePlatformBranding Boolean @default(false) @map("hide_platform_branding")
  customLoginPage      Boolean @default(false) @map("custom_login_page")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
}

// ==================== Phase 4: Enterprise Security ====================

model SsoConfiguration {
  id          String      @id @default(uuid())
  workspaceId String      @unique @map("workspace_id")

  provider    SsoProvider

  // SAML settings
  entityId         String?  @map("entity_id")
  ssoUrl           String?  @map("sso_url")
  sloUrl           String?  @map("slo_url")
  certificate      String?  @db.Text

  // OIDC settings
  clientId         String?  @map("client_id")
  clientSecret     String?  @map("client_secret")
  issuerUrl        String?  @map("issuer_url")

  // Settings
  autoProvision    Boolean  @default(true) @map("auto_provision")
  defaultRole      WorkspaceRole @default(MEMBER) @map("default_role")

  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sso_configurations")
}

enum SsoProvider {
  SAML
  OIDC
  GOOGLE_WORKSPACE
  OKTA
  AZURE_AD
}

model IpAllowlist {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")

  ipAddress   String   @map("ip_address") // Can be CIDR notation
  description String?

  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, ipAddress])
  @@map("ip_allowlists")
}
